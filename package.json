{
  "name": "vercel-blob-ai-sdk",
  "version": "1.0.0",
  "description": "Vercel Blob storage tools for the AI SDK",
  "keywords": [
    "ai",
    "ai-sdk",
    "vercel",
    "blob",
    "storage",
    "tools"
  ],
  "homepage": "https://github.com/vercel-labs/vercel-blob-ai-sdk",
  "bugs": {
    "url": "https://github.com/vercel-labs/vercel-blob-ai-sdk/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ben Sabic",
    "url": "https://bensabic.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/vercel-blob-ai-sdk.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "bump-deps": "npx npm-check-updates -u -p pnpm && pnpm install",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "7.3.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "ai": "^6.0.67",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1"
}
